// ============================================
// StadiumPulse AI - Prisma Schema
// ============================================
// Currently using SQLite for development.
// To switch to PostgreSQL for production, change the provider
// and update DATABASE_URL in .env to a PostgreSQL connection string.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  // PRODUCTION: Change to "postgresql" and update DATABASE_URL
  url      = env("DATABASE_URL")
}

/// User roles for RBAC
/// FAN: General attendees, VOLUNTEER: On-ground helpers,
/// ORGANIZER: Operations staff, ADMIN: Full system access
model User {
  id           String     @id @default(cuid())
  email        String     @unique
  name         String
  passwordHash String
  role         String     @default("FAN") // FAN | VOLUNTEER | ORGANIZER | ADMIN
  language     String     @default("en")
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  // Relations
  sessions     Session[]
  incidents    Incident[] @relation("reporter")
  tasks        Task[]     @relation("assignee")

  @@index([role])
  @@index([email])
}

/// JWT refresh token sessions for token rotation
model Session {
  id           String   @id @default(cuid())
  userId       String
  refreshToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([refreshToken])
}

/// Stadium zones (gates, seating blocks, restrooms, medical, food, exits)
model Zone {
  id        String  @id @default(cuid())
  name      String
  type      String  // GATE | SEATING | RESTROOM | MEDICAL | FOOD_COURT | EXIT | CONCOURSE
  capacity  Int
  floor     Int     @default(0)
  x         Float   @default(0)  // SVG coordinate for map rendering
  y         Float   @default(0)

  // Relations
  gates           Gate[]
  incidentsInZone Incident[] @relation("incidentZone")
  tasksInZone     Task[]     @relation("taskZone")
  crowdSnapshots  CrowdSnapshot[]

  @@index([type])
}

/// Gates with current operational status
model Gate {
  id       String @id @default(cuid())
  name     String
  zoneId   String
  status   String @default("OPEN") // OPEN | RESTRICTED | CLOSED
  
  zone Zone @relation(fields: [zoneId], references: [id])

  @@index([zoneId])
  @@index([status])
}

/// Incident reports from volunteers/staff
model Incident {
  id          String   @id @default(cuid())
  title       String
  description String
  category    String   // MEDICAL | SECURITY | CROWD | FACILITY
  severity    String   @default("LOW") // LOW | MEDIUM | HIGH | CRITICAL
  status      String   @default("OPEN") // OPEN | IN_PROGRESS | RESOLVED | CLOSED
  zoneId      String
  reporterId  String
  photoUrl    String?
  aiSummary   String?  // Gemini-generated categorization summary
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  zone     Zone @relation("incidentZone", fields: [zoneId], references: [id])
  reporter User @relation("reporter", fields: [reporterId], references: [id])

  @@index([category])
  @@index([status])
  @@index([zoneId])
  @@index([createdAt])
}

/// Volunteer task assignments
model Task {
  id          String   @id @default(cuid())
  title       String
  description String
  priority    String   @default("MEDIUM") // LOW | MEDIUM | HIGH | URGENT
  status      String   @default("PENDING") // PENDING | ASSIGNED | IN_PROGRESS | COMPLETED
  zoneId      String
  assigneeId  String?
  dueAt       DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  zone     Zone  @relation("taskZone", fields: [zoneId], references: [id])
  assignee User? @relation("assignee", fields: [assigneeId], references: [id])

  @@index([status])
  @@index([assigneeId])
  @@index([zoneId])
}

/// Multi-language announcements
model Announcement {
  id           String   @id @default(cuid())
  originalText String
  translations String   // JSON string: { en: "...", es: "...", fr: "...", ... }
  priority     String   @default("INFO") // INFO | WARNING | EMERGENCY
  active       Boolean  @default(true)
  createdAt    DateTime @default(now())
  expiresAt    DateTime?

  @@index([active])
  @@index([createdAt])
}

/// Historical crowd density snapshots for AI forecasting
model CrowdSnapshot {
  id        String   @id @default(cuid())
  zoneId    String
  density   Float    // 0.0 to 1.0 (percentage of capacity)
  count     Int      // Absolute headcount
  timestamp DateTime @default(now())

  zone Zone @relation(fields: [zoneId], references: [id])

  @@index([zoneId, timestamp])
  @@index([timestamp])
}
