# ============================================
# StadiumPulse AI - Environment Variables
# ============================================
# Copy this file to .env and fill in your values

# Server
PORT=3001
NODE_ENV=development

# Database (SQLite for dev, swap to PostgreSQL URL for production)
DATABASE_URL="file:./dev.db"
# DATABASE_URL="postgresql://user:password@localhost:5432/stadiumpulse?schema=public"

# JWT Secrets (generate strong random strings for production)
JWT_SECRET="change-me-to-a-strong-random-secret"
JWT_REFRESH_SECRET="change-me-to-another-strong-random-secret"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# Google Gemini API
GEMINI_API_KEY="your-gemini-api-key-here"

# CORS (comma-separated allowed origins)
CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Rate Limiting
AI_RATE_LIMIT_WINDOW_MS=60000
AI_RATE_LIMIT_MAX=20

# Client (prefix with VITE_ for Vite to expose)
VITE_API_URL="http://localhost:3001"
VITE_WS_URL="http://localhost:3001"
